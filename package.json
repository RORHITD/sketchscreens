{
  "name": "sketchscreens-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Auto-generate hand-drawn sketch wireframes of every screen in an app — straight from its source code. (Monorepo root — the published CLI is the `sketchscreens` package under packages/cli.)",
  "license": "MIT",
  "author": {
    "name": "Houston IT Developers",
    "url": "https://houstonitdevelopers.com"
  },
  "homepage": "https://sketchscreens.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/RORHITD/sketchscreens.git"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "dev:renderer": "pnpm --filter @sketchscreens/renderer dev",
    "test:visual": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^5.7.2"
  }
}

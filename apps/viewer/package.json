{
  "name": "@sketchscreens/viewer",
  "version": "0.1.2",
  "description": "A tiny local server that serves the SketchScreens renderer and a map.json, then opens the browser. Local-first: binds to localhost only.",
  "keywords": ["wireframe", "viewer", "localhost", "sketchscreens"],
  "license": "MIT",
  "author": {
    "name": "Houston IT Developers",
    "url": "https://houstonitdevelopers.com"
  },
  "homepage": "https://sketchscreens.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RORHITD/sketchscreens.git",
    "directory": "apps/viewer"
  },
  "bugs": {
    "url": "https://github.com/RORHITD/sketchscreens/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "sketchscreens-view": "./bin/view.js"
  },
  "files": [
    "bin"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sketchscreens/core-schema": "^0.1.3",
    "@sketchscreens/renderer": "^0.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.2"
  }
}

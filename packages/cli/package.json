{
  "name": "sketchscreens",
  "version": "0.1.4",
  "description": "Auto-generate hand-drawn sketch wireframes of an app's screens + user-journey flow, straight from its source code. Local-first, agent-driven.",
  "license": "MIT",
  "author": {
    "name": "Houston IT Developers",
    "url": "https://houstonitdevelopers.com"
  },
  "homepage": "https://sketchscreens.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RORHITD/sketchscreens.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/RORHITD/sketchscreens/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "wireframe",
    "sketch",
    "diagram",
    "codebase",
    "screens",
    "user-flow",
    "documentation",
    "claude",
    "cli"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "sketchscreens": "bin/sketchscreens.js"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "dependencies": {
    "@sketchscreens/core-schema": "^0.1.3",
    "@sketchscreens/extractor": "^0.1.3",
    "@sketchscreens/renderer": "^0.1.3",
    "@sketchscreens/viewer": "^0.1.2"
  }
}

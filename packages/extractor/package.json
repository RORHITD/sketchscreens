{
  "name": "@sketchscreens/extractor",
  "version": "0.1.4",
  "description": "The agent-first extraction contract: the prompt + parse-signal guidance an agent uses to turn a codebase into a ProjectMap, plus a validate-and-write helper.",
  "keywords": [
    "wireframe",
    "extraction",
    "codebase",
    "coverage",
    "sketchscreens"
  ],
  "license": "MIT",
  "author": {
    "name": "Houston IT Developers",
    "url": "https://houstonitdevelopers.com"
  },
  "homepage": "https://sketchscreens.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RORHITD/sketchscreens.git",
    "directory": "packages/extractor"
  },
  "bugs": {
    "url": "https://github.com/RORHITD/sketchscreens/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sketchscreens-write-map": "./bin/write-map.js"
  },
  "files": [
    "dist",
    "src",
    "bin",
    "prompts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@sketchscreens/core-schema": "^0.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

# Link internal @sketchscreens/* deps to the local workspace packages instead
# of the published registry copies. We deliberately use plain semver ranges
# (not the workspace: protocol) in package.json because this repo publishes
# with `npm publish`, which does NOT rewrite workspace: ranges — see the
# 0.1.0/0.1.1 releases that shipped broken for exactly that reason.
link-workspace-packages=true
prefer-workspace-packages=true
# Never rewrite manifest deps to the workspace: protocol on install/update —
# npm publish would ship them verbatim and the tarball would be uninstallable.
save-workspace-protocol=false
